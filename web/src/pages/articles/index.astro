---
import "../../styles/global.css";
import Articles from "../../components/Articles";
import { getArticles } from "../../lib/cms";

const articles = await getArticles();

const siteUrl = "https://thaisurveyorclub.org";
const pageUrl = `${siteUrl}/articles`;
const title = "บทความและข่าวสาร — สมาคมเซอร์เวย์ประเทศไทย";
const description =
  "บทความและข่าวสารล่าสุดจากสมาคมเซอร์เวย์ประเทศไทย ครอบคลุมประเด็นวิชาชีพสำรวจภัย ประกันภัย และพัฒนาการของอุตสาหกรรม";
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="บทความ, ข่าวสาร, สมาคมเซอร์เวย์ประเทศไทย, สำรวจภัย, ประกันภัย"
    />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:site_name" content="Thai Surveyor Association" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0e1b2e" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@200;300;400;500;600;700;800&family=IBM+Plex+Sans+Thai:wght@300;400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen bg-parchment text-ink antialiased">
    <Articles articles={articles} client:load />
  </body>
</html>
